{
  "name": "milemoto-serverside",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm -w @milemoto/types run build",
    "dev": "tsx watch src/server.ts",
    "prestart": "npm -w @milemoto/types run build",
    "start": "node dist/server.js",
    "prebuild": "npm -w @milemoto/types run build",
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "predrizzle:generate": "npm -w @milemoto/types run build",
    "drizzle:generate": "drizzle-kit generate --config drizzle.config.ts",
    "predrizzle:migrate": "npm -w @milemoto/types run build",
    "drizzle:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "migrate": "npm run drizzle:migrate",
    "pretypecheck": "npm -w @milemoto/types run build",
    "typecheck": "tsc --noEmit",
    "test": "set NODE_ENV=test&& vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@milemoto/types": "*",
    "@sendgrid/mail": "^8.1.6",
    "@supabase/supabase-js": "^2.86.0",
    "@types/pdfkit": "^0.17.5",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^1.0.0-beta.2-86f844e",
    "drizzle-orm": "^1.0.0-beta.2-86f844e",
    "drizzle-zod": "^1.0.0-beta.2-86f844e",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.11.3",
    "nodemailer": "^7.0.10",
    "pdfkit": "^0.17.2",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "ulid": "^3.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.3",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.19",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
